---
import type { Card } from '../data/types';
import { purchaseShops, buybackShops, amazonSearchUrl, mercariSearchUrl, toretokuUrl, kanaberuUrl } from '../data/affiliates';

interface Props {
  card: Card;
  /** カード一覧（シリーズ）へのリンク先 例: /card/リーリエの決心 */
  seriesUrl: string;
  /** 「◯◯のカード一覧」に出す表示名 */
  seriesName: string;
  /** 価格基準日（表示用） */
  priceDate: string;
}
const { card, seriesUrl, seriesName, priceDate } = Astro.props;
const id = `modal-${card.slug}`;
const detailUrl = card.path;
const yen = (v: number | null | undefined) => (v == null ? '調査中' : `¥${v.toLocaleString('ja-JP')}`);
const surugayaUrl = card.sellShops.find((s) => s.shop === '駿河屋')?.url ?? card.sellShops[0]?.url;
const amazonUrl = amazonSearchUrl(card);
const mercariUrl = mercariSearchUrl(card);
const toretokuSearchUrl = toretokuUrl(card);
const kanaberuSearchUrl = kanaberuUrl(card);
const shopVisuals: Record<string, { mark: string; logo: string }> = {
  駿河屋: { mark: '', logo: 'surugaya' },
  カードラッシュ: { mark: 'CR', logo: 'cardrush' },
  カーナベル: { mark: 'カ', logo: 'kanaberu' },
  遊々亭: { mark: '遊', logo: 'yuyutei' },
  トレトク: { mark: 'R', logo: 'toretoku' },
  ウリウリトレカ: { mark: 'ウ', logo: 'uriuri' },
  CARDMAX: { mark: 'C', logo: 'cardmax' },
  メルカリ: { mark: '', logo: 'mercari' },
  Amazon: { mark: 'a', logo: 'amazon' },
  'もえたく！': { mark: 'も', logo: 'moetaku' },
};
const shopVisual = (name: string) => shopVisuals[name] ?? { mark: name.slice(0, 1), logo: 'default' };
// 販売ショップの駿河屋は当該カードの商品ページに直リンク、Amazon/メルカリ/トレトク/カーナベルは当該カードの検索結果に直リンク
const purchase = purchaseShops.map((s) => {
  if (s.name === '駿河屋' && surugayaUrl) return { ...s, url: surugayaUrl };
  if (s.name === 'Amazon') return { ...s, url: amazonUrl };
  if (s.name === 'メルカリ') return { ...s, url: mercariUrl };
  if (s.name === 'トレトク') return { ...s, url: toretokuSearchUrl };
  if (s.name === 'カーナベル') return { ...s, url: kanaberuSearchUrl };
  return s;
});
const categoryLabel =
  card.category === 'ポケモン' && card.energyType ? `ポケモン・${card.energyType}` : card.category;

const miniHistory = card.history.slice(-7);
const hasMiniChart = miniHistory.length > 1;
const miniW = 350;
const miniH = 132;
const miniPad = { top: 16, right: 8, bottom: 24, left: 70 };
const miniInnerW = miniW - miniPad.left - miniPad.right;
const miniInnerH = miniH - miniPad.top - miniPad.bottom;
const miniSells = miniHistory.map((p) => p.sell);
const miniMax = hasMiniChart ? Math.max(...miniSells) : 0;
const miniMin = hasMiniChart ? Math.min(...miniSells) : 0;
const miniRange = miniMax - miniMin || miniMax || 1;
const miniX = (i: number) =>
  miniPad.left + (miniInnerW * i) / Math.max(miniHistory.length - 1, 1);
const miniY = (v: number) => miniPad.top + miniInnerH - ((v - miniMin) / miniRange) * miniInnerH;
const miniPath = hasMiniChart
  ? miniSells.map((v, i) => `${i === 0 ? 'M' : 'L'}${miniX(i).toFixed(1)},${miniY(v).toFixed(1)}`).join(' ')
  : '';
const miniDots = hasMiniChart ? miniSells.map((v, i) => ({ cx: miniX(i), cy: miniY(v) })) : [];
const miniTicks = hasMiniChart
  ? [miniMax, Math.round((miniMax + miniMin) / 2), miniMin]
  : [];
const miniXLabels = hasMiniChart
  ? [...new Set([0, Math.floor((miniHistory.length - 1) / 2), miniHistory.length - 1])].map((i) => ({
      x: miniX(i),
      label: miniHistory[i].date.slice(5).replace('-', '/'),
    }))
  : [];
const fmtCompact = (v: number) => `¥${v.toLocaleString('ja-JP')}`;
---

<dialog id={id} class="pm">
  <div class="pm-body">
    <button class="pm-x" data-close-modal aria-label="閉じる">×</button>

    <header class="pm-hd">
      <img class="pm-thumb" src={card.image} alt={`${card.name} ${card.rarity}`} width="116" height="162" loading="lazy" onerror="this.onerror=null;this.src='/images/cards/placeholder.svg'" />
      <div class="pm-hd-main">
        <h2 class="pm-name">{card.name}</h2>
        <div class="pm-chips">
          <span class="chip chip-rarity">{card.rarity}</span>
          <span class="chip">{card.cardNumber}</span>
          <span class="chip">{categoryLabel}</span>
        </div>
        <p class="pm-pack">{card.pack}</p>
      </div>
    </header>

    <!-- 価格（駿河屋） -->
    <div class="pm-hero">
      <div class="hero-tile t-sell">
        <span class="t-cap">
          <svg class="price-cap-icon cart-icon" viewBox="0 0 28 28" aria-hidden="true">
            <path d="M3.5 5.2h4.1l2.3 13.2h12.6l2.1-10.2H8.5" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9.8 10.6h12.8l-1.2 5.8H10.9" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="11.4" cy="23.3" r="1.9" fill="currentColor" />
            <circle cx="21.5" cy="23.3" r="1.9" fill="currentColor" />
          </svg>
          販売価格
        </span>
        <span class="t-val">{yen(card.sellPrice)}</span>
        {card.soldOut && <span class="t-flag">品切れ</span>}
      </div>
      <div class="hero-tile t-buy">
        <span class="t-cap">
          <svg class="price-cap-icon yen-icon" viewBox="0 0 28 28" aria-hidden="true">
            <circle cx="14" cy="14" r="11.2" fill="none" stroke="currentColor" stroke-width="3.2" />
            <path d="M8.8 8.2l5.2 6 5.2-6M14 14.2v7.1M9.5 14.8h9M9.5 18.2h9" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          買取価格
        </span>
        <span class="t-val">{yen(card.buyPrice)}</span>
      </div>
    </div>
    <p class="pm-src">価格は{priceDate}時点。</p>

    <a class="pm-history-card" href={detailUrl}>
      <span class="history-icon" aria-hidden="true"></span>
      <span class="history-copy">
        <strong>価格推移を見る</strong>
        <span>過去の価格推移をグラフで確認できます</span>
      </span>
      <span class="history-chart" aria-hidden="true">
        {hasMiniChart ? (
          <svg viewBox={`0 0 ${miniW} ${miniH}`} preserveAspectRatio="xMidYMid meet">
            {miniTicks.map((tick) => (
              <g>
                <line x1={miniPad.left} y1={miniY(tick)} x2={miniW - miniPad.right} y2={miniY(tick)} />
                <text x={miniPad.left - 8} y={miniY(tick) + 4}>{fmtCompact(tick)}</text>
              </g>
            ))}
            {miniXLabels.map((item) => (
              <text class="x-label" x={item.x} y={miniH - 6}>{item.label}</text>
            ))}
            <path d={miniPath} />
            {miniDots.map((dot) => <circle cx={dot.cx} cy={dot.cy} r="3.2" />)}
          </svg>
        ) : (
          <span class="history-empty">蓄積中</span>
        )}
      </span>
      <span class="history-arrow" aria-hidden="true"></span>
    </a>

    <div class="pm-shops">
      <section class="shop-col shop-buy">
        <h3>
          <svg class="shop-h-icon cart-icon" viewBox="0 0 28 28" aria-hidden="true">
            <path d="M3.5 5.2h4.1l2.3 13.2h12.6l2.1-10.2H8.5" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
            <path d="M9.8 10.6h12.8l-1.2 5.8H10.9" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" />
            <circle cx="11.4" cy="23.3" r="1.9" fill="currentColor" />
            <circle cx="21.5" cy="23.3" r="1.9" fill="currentColor" />
          </svg>
          買えるショップ
        </h3>
        <ul>
          {
            purchase.map((s) => {
              const visual = shopVisual(s.name);
              return (
                <li>
                  <a href={s.url} target="_blank" rel="nofollow sponsored noopener">
                    <span class={`shop-logo logo-${visual.logo}`} aria-hidden="true"><span>{visual.mark}</span></span>
                    <span>{s.name}</span>
                    <span class="shop-go" aria-hidden="true">
                      <svg viewBox="0 0 16 16" focusable="false" fill="none" stroke="#53657d" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4.8 11.2L10.8 5.2" vector-effect="non-scaling-stroke" />
                        <path d="M7.5 5.2h3.3v3.3" vector-effect="non-scaling-stroke" />
                      </svg>
                    </span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>
      <section class="shop-col shop-sell">
        <h3>
          <svg class="shop-h-icon yen-icon" viewBox="0 0 28 28" aria-hidden="true">
            <circle cx="14" cy="14" r="11.2" fill="none" stroke="currentColor" stroke-width="3.2" />
            <path d="M8.8 8.2l5.2 6 5.2-6M14 14.2v7.1M9.5 14.8h9M9.5 18.2h9" fill="none" stroke="currentColor" stroke-width="2.3" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          売れるショップ（買取）
        </h3>
        <ul>
          {
            buybackShops.map((s) => {
              const visual = shopVisual(s.name);
              return (
                <li>
                  <a href={s.url} target="_blank" rel="nofollow sponsored noopener">
                    <span class={`shop-logo logo-${visual.logo}`} aria-hidden="true"><span>{visual.mark}</span></span>
                    <span>{s.name}</span>
                    <span class="shop-go" aria-hidden="true">
                      <svg viewBox="0 0 16 16" focusable="false" fill="none" stroke="#53657d" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M4.8 11.2L10.8 5.2" vector-effect="non-scaling-stroke" />
                        <path d="M7.5 5.2h3.3v3.3" vector-effect="non-scaling-stroke" />
                      </svg>
                    </span>
                  </a>
                </li>
              );
            })
          }
        </ul>
      </section>
    </div>

    <div class="pm-cta">
      <a href={detailUrl} class="cta cta-main"><span class="cta-chart" aria-hidden="true"></span>詳細・価格推移を見る<span class="cta-arrow" aria-hidden="true"></span></a>
      <a href={seriesUrl} class="cta cta-sub"><span class="cta-list" aria-hidden="true"></span>{seriesName} の一覧を見る<span class="cta-arrow" aria-hidden="true"></span></a>
    </div>
    <p class="pm-note">
      <svg class="note-icon" viewBox="0 0 28 28" aria-hidden="true">
        <path d="M14 3.4 23 7v6.4c0 5.3-3.4 9-9 11.2-5.6-2.2-9-5.9-9-11.2V7l9-3.6Z" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linejoin="round" />
        <path d="m10 14.2 2.6 2.6 5.8-6" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
      価格は各ショップの情報をもとに集計しています
    </p>
  </div>
</dialog>

<style>
  .pm {
    width: min(92vw, 860px);
    max-height: 90vh;
    padding: 0;
    border: 0;
    border-radius: 18px;
    overflow: visible;
    color: var(--text);
    background: transparent;
    box-shadow: 0 28px 80px rgba(6, 25, 53, 0.34);
    outline: none;
  }
  .pm:focus { outline: none; }
  .pm::backdrop { background: rgba(15, 23, 42, 0.56); backdrop-filter: blur(5px); }
  .pm-x {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 2;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid #e6eef9;
    background: #fff;
    color: #24364f;
    font-size: 26px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 6px 18px rgba(22, 44, 75, 0.14);
  }
  .pm-x:hover { color: var(--brand); transform: translateY(-1px); }
  .pm-body {
    position: relative;
    padding: 34px 32px 28px;
    overflow-y: auto;
    max-height: 90vh;
    border-radius: 18px;
    border: 0;
    background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
  }

  .pm-hd { display: flex; gap: 24px; align-items: flex-start; padding-right: 56px; }
  .pm-thumb {
    width: 116px;
    height: 162px;
    object-fit: contain;
    border-radius: 10px;
    border: 1px solid var(--border);
    flex: 0 0 auto;
    background: #f7fbff;
    box-shadow: 0 8px 16px rgba(6, 40, 95, 0.12);
  }
  .pm-hd-main { min-width: 0; }
  .pm-name {
    margin: 7px 0 10px;
    color: var(--text-strong);
    font-size: 28px;
    font-weight: 900;
    line-height: 1.25;
  }
  .pm-chips { display: flex; flex-wrap: wrap; gap: 10px; }
  .chip {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 4px 15px;
    border: 1px solid #dce7f5;
    border-radius: 999px;
    background: #f3f7fc;
    color: #607086;
    font-size: 14px;
    font-weight: 900;
    line-height: 1;
  }
  .chip-rarity {
    border-color: var(--brand);
    background: var(--brand);
    color: #fff;
    box-shadow: 0 6px 14px rgba(7, 93, 204, 0.18);
  }
  .pm-pack { margin: 16px 0 0; font-size: 15px; color: #45556b; font-weight: 700; }

  .pm-hero { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 10px 0 0; }
  .hero-tile {
    position: relative;
    min-height: 124px;
    display: grid;
    place-items: center;
    align-content: center;
    border-radius: 10px;
    padding: 22px 18px 20px;
    text-align: center;
    border: 1.5px solid var(--border);
  }
  .t-sell { background: linear-gradient(145deg, #fff9fa, #fff0f2); border-color: #ffc6cf; }
  .t-buy { background: linear-gradient(145deg, #f7fff9, #eafaf0); border-color: #99ddb8; }
  .t-cap {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: #344054;
    font-size: 15px;
    font-weight: 900;
    line-height: 1;
  }
  .price-cap-icon { width: 22px; height: 22px; flex: 0 0 22px; }
  .t-val {
    display: block;
    margin-top: 14px;
    font-size: 44px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: 0;
  }
  .t-sell .t-val { color: #e02e4d; }
  .t-buy .t-val { color: #1c9e5a; }
  .t-sell .t-cap { color: #e02e4d; }
  .t-buy .t-cap { color: #1c9e5a; }
  .t-flag {
    position: absolute;
    top: 10px;
    right: 10px;
    background: #8a94a6;
    color: #fff;
    font-size: 10px;
    font-weight: 800;
    padding: 3px 7px;
    border-radius: 999px;
  }
  .pm-src { font-size: 13px; color: var(--text-sub); text-align: right; margin: 7px 4px 12px; font-weight: 700; }

  .pm-history-card {
    display: grid;
    grid-template-columns: 58px minmax(190px, 1fr) minmax(250px, 1.1fr) 24px;
    gap: 18px;
    align-items: center;
    min-height: 154px;
    margin-top: 10px;
    padding: 18px;
    border: 1px solid #dce8f7;
    border-radius: 10px;
    background: #fff;
    color: var(--text);
    text-decoration: none;
    box-shadow: 0 10px 28px rgba(15, 79, 150, 0.07);
  }
  .pm-history-card:hover { border-color: var(--border-strong); transform: translateY(-1px); }
  .history-icon {
    position: relative;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: linear-gradient(145deg, #edf5ff, #dfeaf8);
  }
  .history-icon::before {
    content: "";
    position: absolute;
    left: 12px;
    top: 12px;
    width: 22px;
    height: 19px;
    border-left: 2px solid var(--brand);
    border-bottom: 2px solid var(--brand);
  }
  .history-icon::after {
    content: "";
    position: absolute;
    left: 16px;
    top: 22px;
    width: 23px;
    height: 14px;
    border-top: 3px solid var(--brand);
    border-right: 3px solid var(--brand);
    transform: skewY(-28deg);
  }
  .history-copy { display: grid; gap: 4px; }
  .history-copy strong { color: var(--text-strong); font-size: 17px; font-weight: 900; line-height: 1.35; }
  .history-copy span { color: var(--text-sub); font-size: 13px; font-weight: 700; }
  .history-chart { min-width: 0; height: 132px; display: block; }
  .history-chart svg { width: 100%; height: 100%; overflow: visible; display: block; }
  .history-chart line { stroke: #e6edf7; stroke-width: 1; }
  .history-chart text { fill: #667085; font-size: 12px; font-weight: 800; text-anchor: end; }
  .history-chart .x-label { text-anchor: middle; }
  .history-chart path { fill: none; stroke: var(--accent-red); stroke-width: 4; stroke-linecap: round; stroke-linejoin: round; }
  .history-chart circle { fill: var(--accent-red); stroke: #fff; stroke-width: 2.5; }
  .history-empty {
    display: grid;
    place-items: center;
    height: 100%;
    border-radius: 10px;
    background: #f7fbff;
    color: var(--text-sub);
    font-weight: 800;
  }
  .history-arrow,
  .cta-arrow,
  .shop-go {
    position: relative;
    display: inline-block;
    width: 13px;
    height: 13px;
    flex: 0 0 auto;
  }
  .history-arrow::before,
  .cta-arrow::before {
    content: "";
    position: absolute;
    inset: 1px 2px 2px 1px;
    border-top: 2px solid currentColor;
    border-right: 2px solid currentColor;
    transform: rotate(45deg);
  }
  .history-arrow { color: var(--brand); justify-self: end; }

  .pm-shops {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-top: 12px;
    padding: 16px;
    border: 1px solid #dce8f7;
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 10px 28px rgba(15, 79, 150, 0.07);
  }
  .shop-col + .shop-col { border-left: 1px solid #dce8f7; padding-left: 24px; }
  .shop-col h3 {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: 0 0 14px;
    color: var(--brand);
    font-size: 16px;
    font-weight: 900;
    line-height: 1.35;
  }
  .shop-sell h3 { color: var(--accent-green); }
  .shop-h-icon {
    position: relative;
    width: 22px;
    height: 22px;
    flex: 0 0 22px;
  }
  .cart-icon {
    overflow: visible;
    color: currentColor;
  }
  .yen-icon { overflow: visible; color: currentColor; }
  .shop-col ul {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    margin: 0;
    padding: 0;
  }
  .shop-col a {
    display: grid;
    grid-template-columns: 24px minmax(0, 1fr) 13px;
    align-items: center;
    gap: 9px;
    min-height: 44px;
    padding: 9px 11px;
    border: 1px solid #dce8f7;
    border-radius: 8px;
    background: #fff;
    color: var(--text);
    text-decoration: none;
    font-size: 12px;
    font-weight: 900;
    line-height: 1.25;
  }
  .shop-col a:hover { border-color: var(--border-strong); color: var(--brand); box-shadow: 0 6px 14px rgba(15, 79, 150, 0.08); }
  .shop-sell a:hover { color: var(--accent-green); }
  .shop-col a span:nth-child(2) { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .shop-logo {
    display: grid;
    place-items: center;
    position: relative;
    width: 24px;
    height: 24px;
    color: #fff;
    font-size: 10px;
    font-weight: 900;
    line-height: 1;
    overflow: visible;
  }
  .shop-logo span { position: relative; z-index: 2; }
  .logo-surugaya {
    border-radius: 50%;
    background: radial-gradient(circle at 62% 35%, #6c57d5 0 22%, #35249a 23% 100%);
  }
  .logo-surugaya::before,
  .logo-surugaya::after {
    content: "";
    position: absolute;
    border: 2px solid #fff;
    border-radius: 50%;
  }
  .logo-surugaya::before { inset: 4px 8px 4px 3px; border-right-color: transparent; transform: rotate(-22deg); }
  .logo-surugaya::after { inset: 7px 4px 7px 9px; border-left-color: transparent; transform: rotate(18deg); }
  .logo-cardrush {
    border-radius: 3px;
    background:
      linear-gradient(135deg, rgba(0, 0, 0, 0.28), transparent 46%),
      linear-gradient(160deg, #ff5a1f, #a41505);
    box-shadow: inset 0 0 0 1px rgba(47, 20, 3, 0.25);
  }
  .logo-cardrush span { color: #111827; font-size: 8px; letter-spacing: -0.4px; text-shadow: 0 1px rgba(255, 255, 255, 0.3); }
  .logo-kanaberu {
    border-radius: 3px;
    background: #ffd82f;
    color: #155bbf;
    box-shadow: inset 0 0 0 1px rgba(201, 157, 0, 0.2);
  }
  .logo-kanaberu::after {
    content: "";
    position: absolute;
    right: 4px;
    top: 5px;
    width: 4px;
    height: 14px;
    background: #2b78ce;
    box-shadow: -5px 3px 0 #2b78ce;
    transform: skewY(-12deg);
  }
