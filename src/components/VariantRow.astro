---
import type { Card } from '../data/types';

interface Props {
  card: Card;
  /** クイック表示ポップアップのボタンを出すか（モーダルを同ページに含める場合のみ true） */
  popup?: boolean;
}
const { card, popup = false } = Astro.props;
const detailUrl = card.path;
const yen = (v: number | null) => (v == null ? '調査中' : `${v.toLocaleString('ja-JP')}円`);
---

<li class="row" data-pack={card.packSlug} data-rarity={card.rarity} data-name={card.name}>
  <a href={detailUrl} class="thumb-link" aria-label={`${card.name} ${card.rarity} の詳細`}>
    <img src={card.image} alt={`${card.name}(${card.rarity})`} width="80" height="112" loading="lazy" onerror="this.onerror=null;this.src='/images/cards/placeholder.svg'" />
  </a>
  <div class="main">
    <a href={detailUrl} class="name">{card.name} <span class="rarity">{card.rarity}</span></a>
    <p class="no">{card.cardNumber} ／ {card.pack}</p>
    <dl class="prices">
      <div><dt>販売</dt><dd class="p-sell">{yen(card.sellPrice)}</dd></div>
      {card.buyPrice != null && <div><dt>買取</dt><dd class="p-buy">{`${card.buyPrice.toLocaleString('ja-JP')}円`}</dd></div>}
      {card.soldOut && <span class="soldout">品切れ</span>}
    </dl>
  </div>
  <div class="actions">
    {popup && <button class="open-btn" data-open-modal={`modal-${card.slug}`}>価格を見る</button>}
    <a href={detailUrl} class="detail-btn">詳細 →</a>
  </div>
</li>

<style>
  .row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--radius);
  }
  .thumb-link { flex: 0 0 auto; }
  .thumb-link img {
    width: 64px;
    height: auto;
    border-radius: 4px;
    border: 1px solid var(--border);
    display: block;
  }
  .main { flex: 1; min-width: 0; }
  .name {
    font-weight: 700;
    font-size: 15px;
    color: var(--text);
    text-decoration: none;
  }
  .name:hover { color: var(--brand); }
  .rarity {
    display: inline-block;
    margin-left: 4px;
    padding: 1px 6px;
    font-size: 11px;
    color: #fff;
    background: var(--brand);
    border-radius: 4px;
    vertical-align: middle;
  }
  .no { margin: 2px 0 6px; font-size: 11px; color: var(--text-sub); }
  .prices { display: flex; gap: 16px; margin: 0; }
  .prices div { display: flex; align-items: baseline; gap: 4px; }
  .prices dt { font-size: 11px; color: var(--text-sub); margin: 0; }
  .prices dd { margin: 0; font-weight: 700; font-size: 14px; }
  .p-sell { color: var(--accent-red); }
  .p-buy { color: #2e7d32; }
  .soldout {
    align-self: center;
    font-size: 10px;
    color: #fff;
    background: #9e9e9e;
    padding: 1px 6px;
    border-radius: 4px;
  }
  .actions {
    flex: 0 0 auto;
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .open-btn {
    padding: 8px 14px;
    border: none;
    background: var(--brand);
    color: #fff;
    font-weight: 700;
    font-size: 13px;
    border-radius: var(--radius);
    cursor: pointer;
    white-space: nowrap;
  }
  .open-btn:hover { background: var(--brand-dark); }
  .detail-btn {
    padding: 6px 14px;
    border: 1px solid var(--brand);
    color: var(--brand);
    font-size: 12px;
    font-weight: 600;
    border-radius: var(--radius);
    text-decoration: none;
    text-align: center;
    white-space: nowrap;
  }
  .detail-btn:hover { background: var(--brand-light); }
  @media (max-width: 480px) {
    .row { flex-wrap: wrap; }
    .actions { flex-direction: row; width: 100%; }
    .open-btn, .detail-btn { flex: 1; }
  }
</style>
