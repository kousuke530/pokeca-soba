---
import type { Card } from '../data/types';

interface Props {
  card: Card;
  /** クイック表示ポップアップのボタンを出すか（モーダルを同ページに含める場合のみ true） */
  popup?: boolean;
}
const { card, popup = false } = Astro.props;
const detailUrl = card.path;
const yen = (v: number | null) => (v == null ? '調査中' : `${v.toLocaleString('ja-JP')}円`);
---

<li class="row" data-pack={card.packSlug} data-rarity={card.rarity} data-name={card.name}>
  <a href={detailUrl} class="thumb-link" aria-label={`${card.name} ${card.rarity} の詳細`}>
    <img src={card.image} alt={`${card.name}(${card.rarity})`} width="80" height="112" loading="lazy" onerror="this.onerror=null;this.src='/images/cards/placeholder.svg'" />
  </a>
  <div class="main">
    <a href={detailUrl} class="name">{card.name} <span class="rarity">{card.rarity}</span></a>
    <p class="no">{card.cardNumber} ／ {card.pack}</p>
    <dl class="prices">
      <div><dt>販売</dt><dd class="p-sell">{yen(card.sellPrice)}</dd></div>
      {card.buyPrice != null && <div><dt>買取</dt><dd class="p-buy">{`${card.buyPrice.toLocaleString('ja-JP')}円`}</dd></div>}
      {card.soldOut && <span class="soldout">品切れ</span>}
    </dl>
  </div>
  <div class="actions">
    {popup && <button class="open-btn" data-open-modal={`modal-${card.slug}`}>価格を見る</button>}
    <a href={detailUrl} class="detail-btn">詳細 →</a>
  </div>
</li>

<style>
  .row {
    display: grid;
    grid-template-columns: 82px minmax(0, 1fr) 210px 132px;
    align-items: center;
    gap: 18px;
    min-height: 118px;
    padding: 16px 22px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: 0 8px 22px rgba(15, 79, 150, 0.04);
  }
  .row:hover { border-color: var(--border-strong); box-shadow: var(--shadow-sm); }
  .thumb-link { display: block; }
  .thumb-link img {
    width: 72px;
    height: 100px;
    object-fit: contain;
    border-radius: 6px;
    display: block;
  }
  .main { flex: 1; min-width: 0; }
  .name {
    color: var(--text-strong);
    font-weight: 900;
    font-size: 17px;
    line-height: 1.45;
    text-decoration: none;
  }
  .name:hover { color: var(--brand); }
  .rarity {
    display: inline-block;
    margin-left: 4px;
    padding: 1px 6px;
    font-size: 11px;
    color: #fff;
    background: var(--brand);
    border-radius: 6px;
    vertical-align: middle;
  }
  .no { margin: 3px 0 0; font-size: 13px; color: var(--text-sub); font-weight: 700; }
  .prices {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin: 0;
    padding-left: 20px;
    border-left: 1px solid var(--border);
  }
  .prices div { display: block; }
  .prices dt { font-size: 12px; color: var(--text-sub); margin: 0; font-weight: 800; }
  .prices dd { margin: 2px 0 0; font-weight: 900; font-size: 18px; line-height: 1.25; }
  .p-sell { color: var(--accent-red); }
  .p-buy { color: var(--accent-green); }
  .soldout {
    align-self: center;
    font-size: 10px;
    color: #fff;
    background: #9e9e9e;
    padding: 1px 6px;
    border-radius: 4px;
  }
  .actions {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .open-btn {
    min-height: 42px;
    padding: 0 14px;
    border: none;
    background: linear-gradient(135deg, var(--brand), #0b75f5);
    color: #fff;
    font-weight: 900;
    font-size: 13px;
    border-radius: 8px;
    cursor: pointer;
    white-space: nowrap;
  }
  .open-btn:hover { background: var(--brand-dark); }
  .detail-btn {
    display: grid;
    place-items: center;
    min-height: 36px;
    padding: 0 14px;
    border: 1px solid var(--brand);
    color: var(--brand);
    font-size: 13px;
    font-weight: 900;
    border-radius: 8px;
    text-decoration: none;
    text-align: center;
    white-space: nowrap;
  }
  .detail-btn:hover { background: var(--brand-light); }
  @media (max-width: 780px) {
    .row {
      grid-template-columns: 70px minmax(0, 1fr);
      gap: 14px;
      padding: 14px;
    }
    .thumb-link img { width: 64px; height: 90px; }
    .prices {
      grid-column: 2;
      padding-left: 0;
      border-left: 0;
    }
    .actions {
      grid-column: 1 / -1;
      flex-direction: row;
    }
    .open-btn, .detail-btn { flex: 1; }
  }
  @media (max-width: 420px) {
    .prices { grid-template-columns: 1fr; gap: 4px; }
  }
</style>
