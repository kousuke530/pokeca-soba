---
import BaseLayout from '../layouts/BaseLayout.astro';
import { series, seriesByPack, topByPrice } from '../data/cards';
import { packs } from '../data/packs';

const title = 'ポケモンカードの買取・販売価格を一括比較｜ポケカ相場ドットコム';
const description =
  'ポケモンカードの最新の販売価格・買取価格を主要ショップ横断で比較。レアリティ別の相場・価格推移をまとめ、最安・高価買取のショップへ直接アクセスできます。';
const yen = (v: number | null) => (v == null ? '調査中' : `${v.toLocaleString('ja-JP')}円`);
const ranking = topByPrice(10);
const packHighlights = packs.slice(0, 6).map((p) => {
  const cards = seriesByPack(p.slug).flatMap((s) => s.variants);
  const top = cards.sort((a, b) => (b.sellPrice ?? 0) - (a.sellPrice ?? 0))[0];
  return { p, top };
});
const keywords = ['リザードンex', 'ピカチュウex', 'ナンジャモ', 'ブラッキーex', 'テラスタル'];
---

<BaseLayout title={title} description={description} path="/">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">価格を比べて、いちばんお得に。</p>
      <h1>ポケカの売買は<span>相場比較</span>で賢くお得に！</h1>
      <p class="hero-lead">
        複数ショップの販売価格・買取価格をまとめてチェック。欲しいカードも、売りたいカードも、最適な価格がすぐ見つかります。
      </p>
      <div class="stats" aria-label="サイト指標">
        <div><span>掲載カード数</span><strong>150,000+</strong><em>件</em></div>
        <div><span>対応ショップ数</span><strong>12+</strong><em>店舗</em></div>
        <div><span>毎日更新</span><strong>最新相場</strong><em>を反映</em></div>
      </div>
      <form class="hero-search" action="/search" method="get">
        <input name="q" type="search" placeholder="カード名で検索（例：リザードンex、ピカチュウ）" aria-label="カード名で検索" />
        <button type="submit">検索</button>
      </form>
      <div class="quick">
        <span>人気のキーワード：</span>
        {keywords.map((k) => <a href={`/search?q=${encodeURIComponent(k)}`}>{k}</a>)}
      </div>
    </div>
    <div class="hero-visual" aria-hidden="true">
      <img src="/logo-icon.png" alt="" class="hero-logo" width="600" height="600" loading="eager" />
    </div>
  </section>

  <section class="sec page-panel ranking-panel">
    <div class="section-head">
      <h2 class="section-title">高額カードランキング</h2>
      <a class="section-link" href="/ranking">ランキングをもっと見る</a>
    </div>
    <ol class="rank-grid">
      {
        ranking.slice(0, 5).map((c) => (
          <li>
            <a href={c.path} class="rank-card">
              <img src={c.image} alt={c.name} width="120" height="168" loading="lazy" />
              <span class="rank-name">{c.name}</span>
              <span class="rank-meta">{c.cardNumber} <span class="badge-rarity">{c.rarity}</span></span>
              <span class="rank-price">{yen(c.sellPrice)}</span>
            </a>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="sec page-panel">
    <div class="section-head">
      <h2 class="section-title">パックから探す</h2>
      <a class="section-link" href="/packs">パック一覧を見る</a>
    </div>
    <ul class="pack-grid">
      {
        packHighlights.map(({ p, top }) => (
          <li>
            <a href={`/pack/${p.slug}`} class="pack-card">
              {top && <img src={top.image} alt="" width="90" height="126" loading="lazy" />}
              <span class="pack-name">{p.shortName}</span>
              <span class="pack-meta">{p.releaseDate} 発売</span>
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="sec page-panel">
    <div class="section-head">
      <h2 class="section-title">注目のカード</h2>
      <a class="section-link" href="/list">注目のカード一覧を見る</a>
    </div>
    <ul class="featured-list">
      {
        ranking.slice(0, 4).map((top) => {
          const s = series.find((x) => x.name === top.name)!;
          return (
            <li>
              <a href={`/list/${s.slug}`} class="featured-card">
                <img src={top.image} alt={s.name} width="56" height="78" loading="lazy" />
                <div>
                  <p class="featured-name">{s.name}</p>
                  <p class="featured-meta">{top.cardNumber} ／ {top.pack}</p>
                  <p class="featured-price">{yen(top.sellPrice)}</p>
                </div>
                <span class="featured-arrow" aria-hidden="true"></span>
              </a>
            </li>
          );
        })
      }
    </ul>
    <p class="price-note">価格は各ショップの販売・買取価格をもとにした参考価格です。最新情報はカード詳細ページをご確認ください。</p>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 520px;
    display: grid;
    grid-template-columns: minmax(650px, 1fr) minmax(300px, 0.55fr);
    gap: 28px;
    align-items: center;
    padding: 28px 18px 40px;
  }
  .hero-copy { position: relative; z-index: 2; min-width: 0; }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    margin: 0 0 18px;
    padding: 7px 18px;
    border: 1px solid #a8c9ff;
    border-radius: 999px;
    color: var(--brand);
    background: rgba(255, 255, 255, 0.88);
    font-size: 14px;
    font-weight: 900;
    box-shadow: var(--shadow-sm);
  }
  .hero h1 {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(31px, 3.45vw, 39px);
    line-height: 1.22;
    letter-spacing: 0;
    font-weight: 900;
    white-space: nowrap;
  }
  .hero h1 span { color: var(--brand); }
  .hero-lead {
    margin: 22px 0 0;
    max-width: 610px;
    color: var(--text);
    font-size: 16px;
    font-weight: 600;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: 560px;
    margin: 28px 0 24px;
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .stats div { padding: 14px 18px; text-align: center; }
  .stats div + div { border-left: 1px solid var(--border); }
  .stats span, .stats em { display: block; color: var(--text-sub); font-size: 12px; font-style: normal; font-weight: 700; }
  .stats strong { display: block; color: var(--brand); font-size: 25px; line-height: 1.35; font-weight: 900; }
  .hero-search {
    display: flex;
    max-width: 620px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 999px;
    box-shadow: var(--shadow);
    overflow: hidden;
  }
  .hero-search input {
    min-width: 0;
    flex: 1;
    border: 0;
    padding: 18px 24px;
    font: inherit;
    font-size: 15px;
  }
  .hero-search input:focus { outline: 0; }
  .hero-search button {
    border: 0;
    min-width: 104px;
    padding: 0 24px;
    color: #fff;
    background: linear-gradient(135deg, var(--brand), #0b75f5);
    font-weight: 900;
    font-size: 15px;
    cursor: pointer;
  }
  .quick {
    display: flex;
    flex-wrap: nowrap;
    gap: 8px;
    align-items: center;
    margin-top: 18px;
    color: var(--text-sub);
    font-size: 13px;
    font-weight: 700;
    overflow-x: auto;
    white-space: nowrap;
    scrollbar-width: none;
  }
  .quick::-webkit-scrollbar { display: none; }
  .quick span, .quick a { flex: 0 0 auto; }
  .quick a {
    padding: 5px 9px;
    border: 1px solid var(--border-strong);
    border-radius: 999px;
    background: #fff;
    text-decoration: none;
    color: var(--text);
  }
  .quick a:hover { color: var(--brand); border-color: var(--brand); }
  .hero-visual {
    position: relative;
    min-height: 410px;
    min-width: 0;
  }
  .hero-visual::before {
    content: "";
    position: absolute;
    inset: 34px 18px 12px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 108, 255, 0.18), transparent 68%);
    filter: blur(4px);
  }
  .hero-logo {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 1;
    width: min(78%, 340px);
    height: auto;
    transform: translate(-50%, -50%);
    filter: drop-shadow(0 22px 32px rgba(6, 40, 95, 0.18));
  }
  .sec { margin: 0 0 26px; padding: 28px 32px; }
  .rank-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    counter-reset: r;
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 22px;
  }
  .rank-grid li { counter-increment: r; min-width: 0; }
  .rank-card {
    position: relative;
    min-height: 330px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 7px;
    padding: 26px 14px 18px;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: inherit;
    text-align: center;
    text-decoration: none;
    background: linear-gradient(180deg, #fff, #fbfdff);
  }
  .rank-card::before {
    content: counter(r);
    position: absolute;
    top: -15px;
    left: 50%;
    transform: translateX(-50%);
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #fff;
    border: 2px solid #dce8f8;
    color: var(--brand);
    font-weight: 900;
  }
  .rank-grid li:nth-child(-n + 3) .rank-card::before {
    border: 0;
    color: #fff;
    background: linear-gradient(145deg, #ffc928, #c87913);
  }
  .rank-card:hover { border-color: var(--brand); box-shadow: var(--shadow-sm); }
  .rank-card img {
    width: 122px;
    height: 170px;
    object-fit: contain;
    border-radius: 6px;
  }
  .rank-name {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 42px;
    color: var(--text-strong);
    font-size: 15px;
    line-height: 1.45;
    font-weight: 900;
  }
  .rank-meta { color: var(--text-sub); font-size: 12px; }
  .rank-price { color: var(--accent-red); font-size: 20px; line-height: 1.2; font-weight: 900; }
  .pack-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 18px;
  }
  .pack-grid li { display: flex; }
  .pack-card {
    flex: 1;
    min-height: 190px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
    padding: 16px 12px 14px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }
  .pack-card:hover { border-color: var(--brand); box-shadow: var(--shadow-sm); }
  .pack-card img { width: 78px; height: 108px; object-fit: contain; border-radius: 5px; }
  .pack-name {
    min-height: 41px;
    font-weight: 900;
    font-size: 14px;
    line-height: 1.45;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .pack-meta { color: var(--text-sub); font-size: 12px; }
  .featured-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }
  .featured-list li { display: flex; min-width: 0; }
  .featured-card {
    flex: 1;
    min-height: 156px;
    display: grid;
    grid-template-columns: 74px minmax(0, 1fr) 32px;
    align-items: center;
    gap: 12px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    background: #fff;
  }
  .featured-card:hover { border-color: var(--brand); box-shadow: var(--shadow-sm); }
  .featured-card img { width: 74px; height: 104px; object-fit: contain; border-radius: 5px; }
  .featured-name {
    margin: 0;
    color: var(--text-strong);
    font-size: 15px;
    font-weight: 900;
    line-height: 1.4;
    min-height: 42px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured-meta {
    margin: 4px 0 8px;
    color: var(--text-sub);
    font-size: 11px;
    line-height: 1.45;
    min-height: 32px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .featured-price {
    margin: 0;
    color: var(--accent-red);
    font-size: 18px;
    line-height: 1.2;
    font-weight: 900;
    white-space: nowrap;
  }
  .featured-arrow {
    position: relative;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: var(--brand-light);
    color: var(--brand);
  }
  .featured-arrow::before {
    content: "";
    width: 8px;
    height: 8px;
    border-top: 3px solid currentColor;
    border-right: 3px solid currentColor;
    transform: translateX(-1px) rotate(45deg);
  }
  .price-note {
    margin: 22px 0 0;
    padding: 13px 18px;
    border-radius: 10px;
    color: #6a4a00;
    background: #fff7d9;
    font-size: 13px;
    font-weight: 700;
    text-align: center;
  }
  @media (max-width: 900px) {
    .hero { grid-template-columns: 1fr; min-height: 0; padding-top: 16px; }
    .hero-visual { min-height: 300px; order: -1; overflow: hidden; }
    .hero h1 { font-size: 38px; white-space: normal; overflow-wrap: anywhere; }
    .rank-grid, .featured-list { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .pack-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .hero { padding: 8px 0 28px; }
    .hero h1 { font-size: 32px; }
    .hero-visual { min-height: 220px; }
    .hero-logo { width: min(76%, 260px); }
    .stats { grid-template-columns: 1fr; }
    .stats div + div { border-left: 0; border-top: 1px solid var(--border); }
    .hero-search { border-radius: 14px; }
    .hero-search input { padding: 14px; font-size: 14px; }
    .hero-search button { min-width: 82px; padding: 0 16px; }
    .sec { padding: 22px 16px; }
    .rank-grid { gap: 16px; }
    .rank-card { min-height: 292px; padding-inline: 10px; }
    .rank-card img { width: 96px; height: 134px; }
    .pack-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
    .featured-list { grid-template-columns: 1fr; }
  }
</style>
