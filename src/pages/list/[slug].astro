---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import VariantRow from '../../components/VariantRow.astro';
import PriceModal from '../../components/PriceModal.astro';
import { series as allSeries, priceAsOf } from '../../data/cards';
import type { CardSeries } from '../../data/types';

export function getStaticPaths() {
  return allSeries.map((s) => ({ params: { slug: s.slug }, props: { series: s } }));
}

interface Props {
  series: CardSeries;
}
const { series } = Astro.props;

const priceDate = priceAsOf;
const priceDateShort = priceDate.replace(/^(\d{4})年(\d{1,2})月(\d{1,2})日$/, '$1/$2/$3');
const seriesPath = `/list/${series.slug}`;
const variants = [...series.variants].sort((a, b) => (b.sellPrice ?? 0) - (a.sellPrice ?? 0));
const topCard = variants[0];
const priceVals = variants.map((v) => v.sellPrice).filter((v): v is number => v != null);
const buyVals = variants.map((v) => v.buyPrice).filter((v): v is number => v != null);
const lowest = priceVals.length ? Math.min(...priceVals) : null;
const highest = priceVals.length ? Math.max(...priceVals) : null;
const avg = priceVals.length ? Math.round(priceVals.reduce((sum, v) => sum + v, 0) / priceVals.length) : null;
const yen = (v: number | null) => (v == null ? '調査中' : `${v.toLocaleString('ja-JP')}円`);
const typeLabel =
  topCard.category === 'ポケモン' && topCard.energyType ? topCard.energyType : topCard.category;

const title = `${series.name}(全${series.variants.length}種)の買取・販売価格相場一覧【ポケカ】`;
const description = `${series.name}の最新の販売価格・買取価格を比較。レアリティ別（${series.variants
  .map((v) => v.rarity)
  .join('・')}）の相場をまとめています。`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: title,
  itemListElement: series.variants.map((c, i) => {
    const prices = c.sellShops.map((s) => s.price).filter((p): p is number => p != null);
    return {
      '@type': 'ListItem',
      position: i + 1,
      url: new URL(c.path, Astro.site).href,
      item: {
        '@type': 'Product',
        name: `${c.name}(${c.rarity}) ${c.cardNumber}`,
        category: c.category,
        image: new URL(c.image, Astro.site).href,
        ...(prices.length
          ? {
              offers: {
                '@type': 'AggregateOffer',
                priceCurrency: 'JPY',
                lowPrice: Math.min(...prices),
                highPrice: Math.max(...prices),
                offerCount: prices.length,
                availability: 'https://schema.org/InStock',
              },
            }
          : {}),
      },
    };
  }),
});
---

<BaseLayout title={title} description={description} path={seriesPath} jsonLd={jsonLd}>
  <Breadcrumbs
    items={[
      { label: 'ポケカ買取・販売価格相場TOP', href: '/' },
      { label: 'ポケモン一覧', href: '/list' },
      { label: series.name },
    ]}
  />

  <section class="pokemon-hero">
    <figure class="hero-img">
      <img src={topCard.imageLarge} alt={series.name} width="280" height="390" loading="eager" />
      <figcaption>画像出典: 駿河屋</figcaption>
    </figure>
    <div class="hero-copy">
      <div class="chips">
        <span>{typeLabel}</span>
        <span>{topCard.category}</span>
      </div>
      <h1 class="page-title">{series.name}</h1>
      <p class="lead">
        {series.name}のレアリティ別カード相場を一覧で確認できます。価格は{priceDate}時点の参考相場です。
      </p>
      <div class="stats">
        <div><span>収録バージョン</span><strong>{series.variants.length}種</strong></div>
        <div><span>最安値</span><strong>{yen(lowest)}</strong></div>
        <div><span>最高値</span><strong>{yen(highest)}</strong></div>
        <div class="stat-date"><span>価格更新</span><strong>{priceDateShort}</strong></div>
      </div>
    </div>
  </section>

  <section class="tabs" aria-label="表示切り替え">
    <a href="#variants" class="active">カードバージョン一覧</a>
    <a href="#chart">相場チャート</a>
  </section>

  <section id="variants" class="variant-section page-panel">
    <div class="variant-tools">
      <div>
        <label><select><option>すべてのレアリティ</option></select></label>
        <label><select><option>すべてのシリーズ</option></select></label>
      </div>
      <label>並び替え：<select><option>価格が高い順</option></select></label>
    </div>
    <div class="section-head">
      <h2 class="section-title">{series.variants.length}件のバリエーション</h2>
      <p class="avg">平均相場 {yen(avg)}</p>
    </div>
    <ul class="card-list">
      {variants.map((c) => <VariantRow card={c} popup />)}
    </ul>
  </section>

  <section id="chart" class="notice">
    価格は主要カードショップの最安値を基に算出しています。更新時間により価格や在庫が変動する場合があります。
  </section>

  {
    variants.map((c) => (
      <PriceModal card={c} seriesUrl={seriesPath} seriesName={series.name} priceDate={priceDate} />
    ))
  }
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-open-modal]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-open-modal');
      if (id) (document.getElementById(id) as HTMLDialogElement | null)?.showModal();
    });
  });
  document.querySelectorAll<HTMLButtonElement>('[data-close-modal]').forEach((btn) => {
    btn.addEventListener('click', () => btn.closest('dialog')?.close());
  });
  document.querySelectorAll<HTMLDialogElement>('dialog.pm').forEach((dlg) => {
    dlg.addEventListener('click', (e) => {
      if (e.target === dlg) dlg.close();
    });
  });
</script>

<style>
  .pokemon-hero {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: 34px;
    align-items: center;
    min-height: 330px;
    padding: 18px 0 44px;
  }
  .hero-img {
    margin: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }
  .hero-img img {
    width: 260px;
    height: 362px;
    object-fit: contain;
    border-radius: 14px;
    filter: drop-shadow(0 18px 22px rgba(6, 40, 95, 0.16));
  }
  .hero-img figcaption {
    margin-top: 8px;
    color: var(--text-sub);
    font-size: 11px;
    font-weight: 700;
    text-align: center;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 14px;
  }
  .chips span {
    padding: 7px 16px;
    border-radius: 999px;
    color: #fff;
    background: #31a866;
    font-size: 14px;
    font-weight: 900;
  }
  .chips span + span { color: var(--text); background: #eef4fb; }
  .page-title {
    margin: 0 0 14px;
    color: var(--text-strong);
    font-size: clamp(34px, 5vw, 50px);
    line-height: 1.25;
    font-weight: 900;
  }
  .lead {
    max-width: 720px;
    color: var(--text);
    font-size: 16px;
    font-weight: 600;
    margin: 0 0 26px;
  }
  .stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    background: rgba(255, 255, 255, 0.94);
    border: 1px solid var(--border);
    border-radius: 16px;
    box-shadow: var(--shadow-sm);
    overflow: hidden;
  }
  .stats div {
    min-height: 84px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 14px 20px;
  }
  .stats div + div { border-left: 1px solid var(--border); }
  .stats span { color: var(--text-sub); font-size: 12px; font-weight: 800; }
  .stats strong { color: var(--brand); font-size: 22px; line-height: 1.35; font-weight: 900; white-space: nowrap; }
  .stats .stat-date strong { font-size: 21px; }
  .tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    margin: 0 0 26px;
    border-bottom: 1px solid var(--border);
  }
  .tabs a {
    padding: 18px 16px 14px;
    color: var(--text-sub);
    text-align: center;
    text-decoration: none;
    font-size: 17px;
    font-weight: 900;
    border-bottom: 4px solid transparent;
  }
  .tabs a.active {
    color: var(--brand);
    border-color: var(--brand);
  }
  .variant-section {
    padding: 26px 0 0;
    box-shadow: none;
    border: 0;
    background: transparent;
  }
  .variant-tools {
    display: flex;
    justify-content: space-between;
    gap: 18px;
    align-items: center;
    margin-bottom: 22px;
  }
  .variant-tools > div {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .variant-tools label {
    color: var(--text-sub);
    font-size: 13px;
    font-weight: 800;
  }
  .variant-tools select {
    min-height: 44px;
    min-width: 170px;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 14px;
    background: #fff;
    font: inherit;
    font-weight: 700;
  }
  .avg {
    margin: 0;
    color: var(--text-sub);
    font-size: 14px;
    font-weight: 800;
  }
  .card-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 10px; }
  .notice {
    margin: 26px 0 0;
    padding: 14px 18px;
    border: 1px solid #f3df9a;
    border-radius: 10px;
    color: #6a4a00;
    background: #fff7d9;
    font-size: 13px;
    font-weight: 700;
  }
  @media (max-width: 820px) {
    .pokemon-hero { grid-template-columns: 1fr; gap: 18px; }
    .stats { grid-template-columns: 1fr 1fr; }
    .stats div:nth-child(odd) { border-left: 0; }
    .stats div:nth-child(n + 3) { border-top: 1px solid var(--border); }
    .variant-tools { align-items: stretch; flex-direction: column; }
  }
  @media (max-width: 520px) {
    .hero-img img { width: 220px; height: 306px; }
    .page-title { font-size: 34px; }
    .stats { grid-template-columns: 1fr; }
    .stats div + div { border-left: 0; border-top: 1px solid var(--border); }
    .tabs a { font-size: 14px; }
    .variant-tools select { width: 100%; }
    .variant-tools > div { display: grid; grid-template-columns: 1fr; }
  }
</style>
