---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import PriceHistoryChart from '../../../components/PriceHistoryChart.astro';
import ShopLinks from '../../../components/ShopLinks.astro';
import { purchaseShops, buybackShops } from '../../../data/affiliates';
import { allCards, getSeriesByName, seriesByPack, priceAsOf } from '../../../data/cards';
import { getPack } from '../../../data/packs';
import type { Card } from '../../../data/types';

export function getStaticPaths() {
  const seen = new Set<string>();
  const paths: { params: { slug: string; card: string }; props: { card: Card } }[] = [];
  for (const card of allCards) {
    const cardParam = `${card.cardNumber.replace(/\//g, '-')}-${card.raritySlug}`;
    const key = `${card.nameSlug}/${cardParam}`;
    if (seen.has(key)) continue; // 同一URLの重複を除去（getStaticPaths重複回避）
    seen.add(key);
    paths.push({ params: { slug: card.nameSlug, card: cardParam }, props: { card } });
  }
  return paths;
}

interface Props {
  card: Card;
}
const { card } = Astro.props;

const priceDate = priceAsOf;
const setCode = getPack(card.packSlug)?.setCode ?? card.packSlug.toUpperCase();
const yen = (v: number | null) => (v == null ? '調査中' : `¥${v.toLocaleString('ja-JP')}`);
const surugayaUrl = card.sellShops.find((s) => s.shop === '駿河屋')?.url ?? card.sellShops[0]?.url;
// 販売ショップの駿河屋は、可能なら当該カードの商品ページに直リンク
const purchase = surugayaUrl
  ? purchaseShops.map((s) => (s.name === '駿河屋' ? { ...s, url: surugayaUrl } : s))
  : purchaseShops;
const categoryLabel =
  card.category === 'ポケモン' && card.energyType ? `ポケモン・${card.energyType}` : card.category;
const isPokemon = card.category === 'ポケモン';
const listUrl = `/list/${card.nameSlug}`;

const otherVariants = (getSeriesByName(card.name)?.variants ?? []).filter((v) => v.id !== card.id);
const samePack = seriesByPack(card.packSlug)
  .filter((s) => s.name !== card.name)
  .map((s) => s.variants.reduce((a, b) => ((b.sellPrice ?? 0) > (a.sellPrice ?? 0) ? b : a)))
  .sort((a, b) => (b.sellPrice ?? 0) - (a.sellPrice ?? 0))
  .slice(0, 6);

const crumbLabel = `${card.name}【${card.rarity}】${setCode} ${card.cardNumber}`;
const title = `${card.name}(${card.rarity}) ${setCode} ${card.cardNumber} の買取・販売価格相場【ポケカ】`;
const description = `${card.name}(${card.rarity})の最新の販売価格は${yen(card.sellPrice)}、買取価格は${yen(
  card.buyPrice,
)}（${priceDate}時点）。${card.pack}収録。価格推移もまとめています。`;

const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: `${card.name}(${card.rarity}) ${card.cardNumber}`,
  image: new URL(card.imageLarge, Astro.site).href,
  category: card.category,
  sku: card.cardNumber,
  description,
  ...(card.sellPrice != null
    ? {
        offers: {
          '@type': 'Offer',
          priceCurrency: 'JPY',
          price: card.sellPrice,
          availability: card.soldOut
            ? 'https://schema.org/OutOfStock'
            : 'https://schema.org/InStock',
          ...(surugayaUrl ? { url: new URL(surugayaUrl, 'https://www.suruga-ya.jp').href } : {}),
        },
      }
    : {}),
});
---

<BaseLayout title={title} description={description} path={card.path} jsonLd={jsonLd}>
  <Breadcrumbs
    items={[
      { label: 'ポケカ買取・販売価格相場TOP', href: '/' },
      { label: 'ポケモン一覧', href: '/list' },
      { label: card.name, href: listUrl },
      { label: crumbLabel },
    ]}
  />

  <!-- 検索インデックス対象（Pagefind）: カード名・レア・型番・パック -->
  <div data-pagefind-body data-pagefind-meta={`title:${card.name}（${card.rarity}）`}>
    <section class="detail-hero">
      <div class="gallery">
        <figure class="hero-img">
          <img
            src={card.imageLarge}
            alt={`${card.name}(${card.rarity}) ${card.cardNumber}`}
            width="420"
            height="586"
            loading="eager"
            data-pagefind-meta="image[src], image_alt[alt]"
            onerror="this.onerror=null;this.src='/images/cards/placeholder.svg'"
          />
          <figcaption>画像出典: 駿河屋</figcaption>
        </figure>
        <div class="thumbs" aria-label="関連カード画像">
          <img src={card.image} alt="" width="48" height="67" loading="lazy" />
          {otherVariants.slice(0, 3).map((v) => <a href={v.path}><img src={v.image} alt="" width="48" height="67" loading="lazy" /></a>)}
        </div>
      </div>

      <div class="detail-main">
        <div class="head-row">
          <span class="badge-rarity" data-pagefind-filter="レアリティ">{card.rarity}</span>
          <div class="mini-actions">
            <span>お気に入り</span>
            <span>シェア</span>
          </div>
        </div>
        <h1 class="ttl">{card.name}</h1>
        <p class="ttl-sub">{setCode} {card.cardNumber} ／ {card.pack}</p>
        <span hidden data-pagefind-filter="パック">{card.pack}</span>

        <div class="price-cards">
          <div class="price-card sell">
            <span class="pcap">販売価格（最安値）</span>
            <strong>{yen(card.sellPrice)}</strong>
            <span class="delta">価格は{priceDate}時点</span>
            {surugayaUrl && <a href={surugayaUrl} target="_blank" rel="nofollow sponsored noopener">ショップで探す</a>}
          </div>
          <div class="price-card buy">
            <span class="pcap">買取価格（最高値）</span>
            <strong>{yen(card.buyPrice)}</strong>
            <span class="delta">買取可否は各ショップで確認</span>
            <a href="#buy-shops">買取価格を比較</a>
          </div>
        </div>

        <dl class="spec">
          <div><dt>カード種別</dt><dd>{card.category}</dd></div>
          <div><dt>タイプ</dt><dd>{card.energyType || 'なし'}</dd></div>
          <div><dt>レギュレーション</dt><dd>{setCode}</dd></div>
          <div><dt>発売日</dt><dd>{getPack(card.packSlug)?.releaseDate ?? '調査中'}</dd></div>
          <div><dt>収録パック</dt><dd><a href={`/pack/${card.packSlug}`}>{card.pack}</a></dd></div>
          <div><dt>カード番号</dt><dd>{card.cardNumber}</dd></div>
        </dl>
      </div>
    </section>

    <p class="lead">
      {card.name}（{card.rarity}・{setCode} {card.cardNumber}）の最新相場は
      <strong>販売 {yen(card.sellPrice)}</strong> / <strong>買取 {yen(card.buyPrice)}</strong>です（{priceDate}時点）。
    </p>
  </div>
  <!-- /検索インデックス対象 -->

  <section class="market page-panel">
    <nav class="market-tabs" aria-label="カード詳細メニュー">
      <a href="#price-chart" class="active">価格推移</a>
      <a href="#shops">販売・買取一覧</a>
      <a href="#card-info">カード情報</a>
      <a href="#deck">デッキ採用</a>
    </nav>
    <div class="market-grid" id="price-chart">
      <div class="chart-box">
        <h2>価格推移</h2>
        <PriceHistoryChart history={card.history} />
      </div>
      <aside class="market-status">
        <h2>マーケット状況</h2>
        <dl>
          <div><dt>販売中の最安値</dt><dd class="sell">{yen(card.sellPrice)}</dd></div>
          <div><dt>買取の最高値</dt><dd class="buy">{yen(card.buyPrice)}</dd></div>
          <div><dt>売り切れ</dt><dd>{card.soldOut ? 'あり' : 'なし'}</dd></div>
        </dl>
      </aside>
    </div>
  </section>

  <div id="shops" class="shops-wrap">
    <ShopLinks title="このカードを買えるショップ" shops={purchase} variant="buy" />
    <div id="buy-shops">
      <ShopLinks title="このカードを売れるショップ（買取）" shops={buybackShops} variant="sell" />
    </div>
  </div>

  {
    otherVariants.length > 0 && (
      <section class="sec">
        <h2 class="sec-h">
          {card.name} の他レアリティ
          {isPokemon && <a class="sec-link" href={listUrl}>一覧 →</a>}
        </h2>
        <ul class="rel-cards">{otherVariants.slice(0, 4).map((v) => (
          <li>
            <a href={v.path} class:list={[v.id === card.id && 'active']}>
              <img src={v.image} alt={v.name} width="78" height="109" loading="lazy" />
              <span>{v.name}</span>
              <em>{v.rarity}</em>
              <strong>販売 {yen(v.sellPrice)}</strong>
              {v.buyPrice != null && <small>買取 {yen(v.buyPrice)}</small>}
            </a>
          </li>
        ))}</ul>
      </section>
    )
  }

  {
    samePack.length > 0 && (
      <section class="sec">
        <h2 class="sec-h">「{card.pack}」の高額カード</h2>
        <ul class="pack-cards">{samePack.map((v, i) => (
          <li>
            <a href={v.path}>
              <span class="rank">{i + 1}</span>
              <img src={v.image} alt={v.name} width="96" height="134" loading="lazy" />
              <span>{v.name}</span>
              <em>{v.rarity} {v.cardNumber}</em>
              <strong>販売 {yen(v.sellPrice)}</strong>
            </a>
          </li>
        ))}</ul>
      </section>
    )
  }
</BaseLayout>

<style>
  .detail-hero {
    display: grid;
    grid-template-columns: minmax(260px, 340px) minmax(0, 1fr);
    gap: 32px;
    align-items: start;
    padding: 14px 0 42px;
  }
  .gallery { min-width: 0; }
  .hero-img {
    margin: 0;
    text-align: center;
  }
  .hero-img img {
    width: min(100%, 340px);
    border-radius: 18px;
    display: block;
    margin: 0 auto;
    filter: drop-shadow(0 20px 28px rgba(6, 40, 95, 0.18));
  }
  .hero-img figcaption { font-size: 11px; color: var(--text-sub); text-align: center; margin-top: 8px; }
  .thumbs {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin-top: 18px;
  }
  .thumbs img {
    width: 54px;
    height: 76px;
    object-fit: contain;
    border: 1px solid var(--border);
    border-radius: 6px;
    background: #fff;
  }
  .head-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 10px;
  }
  .mini-actions {
    display: flex;
    gap: 10px;
  }
  .mini-actions span {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 0 14px;
    border: 1px solid var(--border);
    border-radius: 7px;
    color: var(--brand);
    background: #fff;
    font-size: 13px;
    font-weight: 900;
  }
  .ttl {
    margin: 0;
    color: var(--text-strong);
    font-size: clamp(34px, 5vw, 50px);
    font-weight: 900;
    line-height: 1.25;
    letter-spacing: 0;
  }
  .ttl-sub {
    margin: 10px 0 26px;
    color: var(--text-sub);
    font-size: 15px;
    font-weight: 800;
  }
  .price-cards {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 14px;
    margin-bottom: 18px;
  }
  .price-card {
    min-width: 0;
    padding: 20px 16px 18px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #fff;
    text-align: center;
    box-shadow: var(--shadow-sm);
  }
  .price-card.sell { border-color: #ffd2d7; }
  .price-card.buy { border-color: #bfead1; }
  .pcap {
    display: block;
    font-size: 15px;
    font-weight: 900;
  }
  .sell .pcap { color: var(--accent-red); }
  .buy .pcap { color: var(--accent-green); }
  .price-card strong {
    display: block;
    margin-top: 8px;
    color: var(--text-strong);
    font-size: clamp(28px, 4vw, 42px);
    line-height: 1.1;
    font-weight: 900;
  }
  .sell strong { color: var(--accent-red); }
  .delta {
    display: block;
    margin: 8px 0 18px;
    color: var(--text-sub);
    font-size: 13px;
    font-weight: 800;
  }
  .price-card a {
    display: grid;
    place-items: center;
    min-height: 46px;
    border-radius: 8px;
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    font-weight: 900;
  }
  .sell a { background: linear-gradient(135deg, #f01f32, #e50012); }
  .buy a { background: linear-gradient(135deg, #25b45e, #14964a); }
  .spec {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 22px;
    margin: 18px 0 0;
    padding: 18px 22px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #fff;
    box-shadow: var(--shadow-sm);
  }
  .spec div {
    display: grid;
    grid-template-columns: 104px minmax(0, 1fr);
    gap: 12px;
    padding: 11px 0;
    border-bottom: 1px solid var(--border);
  }
  .spec div:nth-last-child(-n + 2) { border-bottom: 0; }
  .spec dt { margin: 0; color: #14356c; font-size: 13px; font-weight: 900; }
  .spec dd { margin: 0; color: var(--text); font-size: 13px; font-weight: 700; }
  .spec a { text-decoration: none; }
  .lead {
    margin: -16px 0 34px;
    color: var(--text);
    font-size: 15px;
    font-weight: 700;
    line-height: 1.9;
  }
  .market {
    padding: 0 24px 24px;
  }
  .market-tabs {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-bottom: 1px solid var(--border);
  }
  .market-tabs a {
    padding: 18px 8px 14px;
    color: #14356c;
    text-align: center;
    text-decoration: none;
    font-size: 15px;
    font-weight: 900;
    border-bottom: 4px solid transparent;
  }
  .market-tabs a.active {
    color: var(--brand);
    border-color: var(--brand);
  }
  .market-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 300px;
    gap: 22px;
    padding-top: 24px;
  }
  .chart-box, .market-status {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: #fff;
    padding: 20px;
  }
  .chart-box h2, .market-status h2 {
    margin: 0 0 14px;
    color: var(--text-strong);
    font-size: 20px;
    font-weight: 900;
  }
  .market-status dl { margin: 0; }
  .market-status div {
    display: flex;
    justify-content: space-between;
    gap: 16px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
  }
  .market-status div:last-child { border-bottom: 0; }
  .market-status dt { margin: 0; color: #14356c; font-size: 13px; font-weight: 900; }
  .market-status dd { margin: 0; color: var(--text); font-weight: 900; }
  .market-status .sell { color: var(--accent-red); }
  .market-status .buy { color: var(--accent-green); }
  .shops-wrap { margin-top: 4px; }
  .sec { margin-top: 34px; }
  .sec-h {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin: 0 0 16px;
    color: var(--text-strong);
    font-size: 22px;
    font-weight: 900;
  }
  .sec-link { color: var(--brand); font-size: 13px; font-weight: 900; text-decoration: none; }
  .rel-cards, .pack-cards {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 16px;
  }
  .rel-cards { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  .pack-cards { grid-template-columns: repeat(6, minmax(0, 1fr)); }
  .rel-cards a, .pack-cards a {
    position: relative;
    min-height: 184px;
    display: flex;
    flex-direction: column;
    gap: 5px;
    align-items: center;
    padding: 14px 12px;
    border: 1px solid var(--border);
    border-radius: 12px;
    color: inherit;
    background: #fff;
    text-align: center;
    text-decoration: none;
  }
  .rel-cards a:hover, .pack-cards a:hover { border-color: var(--brand); box-shadow: var(--shadow-sm); }
  .rel-cards img, .pack-cards img {
    width: 82px;
    height: 114px;
    object-fit: contain;
    border-radius: 5px;
  }
  .rel-cards span, .pack-cards span:not(.rank) {
    color: var(--text-strong);
    font-size: 13px;
    line-height: 1.4;
    font-weight: 900;
  }
  .rel-cards em, .pack-cards em, .rel-cards small {
    color: var(--text-sub);
    font-size: 11px;
    font-style: normal;
    font-weight: 700;
  }
  .rel-cards strong, .pack-cards strong {
    color: var(--accent-red);
    font-size: 13px;
    font-weight: 900;
  }
  .pack-cards .rank {
    position: absolute;
    top: -12px;
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(145deg, #ffc928, #c87913);
    font-size: 15px;
    font-weight: 900;
  }
  @media (max-width: 920px) {
    .detail-hero { grid-template-columns: 1fr; gap: 24px; }
    .market-grid { grid-template-columns: 1fr; }
    .rel-cards, .pack-cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 620px) {
    .ttl { font-size: 34px; }
    .head-row { align-items: flex-start; flex-direction: column; }
    .price-cards, .spec, .market-tabs { grid-template-columns: 1fr; }
    .spec div, .spec div:nth-last-child(-n + 2) { border-bottom: 1px solid var(--border); }
    .spec div:last-child { border-bottom: 0; }
    .lead { margin-top: 0; }
    .market { padding: 0 16px 18px; }
    .market-tabs a { border-bottom-width: 2px; }
    .rel-cards, .pack-cards { grid-template-columns: 1fr 1fr; gap: 12px; }
  }
</style>
