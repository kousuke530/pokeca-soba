---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { pokemonSeries } from '../../data/cards';

const list = pokemonSeries().sort((a, b) => a.name.localeCompare(b.name, 'ja'));
const entries = list.map((s) => {
  const top = [...s.variants].sort((a, b) => (b.sellPrice ?? 0) - (a.sellPrice ?? 0))[0];
  return {
    series: s,
    top,
    type: top?.energyType || 'その他',
    initial: kanaGroup(s.name),
  };
});
const popular = [...entries].sort((a, b) => (b.top?.sellPrice ?? 0) - (a.top?.sellPrice ?? 0)).slice(0, 8);
const typeFilters = ['すべて', ...new Set(entries.map((e) => e.type).filter(Boolean))];
const initialFilters = ['すべて', 'ア', 'カ', 'サ', 'タ', 'ナ', 'ハ', 'マ', 'ヤ', 'ラ', 'ワ', 'A-Z', 'その他'];
const title = 'ポケモン一覧｜ポケカ相場ドットコム';
const description =
  'ポケモンカードをポケモンごとに一覧。各ポケモンの販売価格・買取価格・価格推移を確認できます。';

function kanaGroup(name: string): string {
  const c = name[0] ?? '';
  if (/^[A-Za-z0-9]/.test(c)) return 'A-Z';
  if ('アイウエオヴ'.includes(c)) return 'ア';
  if ('カキクケコガギグゲゴ'.includes(c)) return 'カ';
  if ('サシスセソザジズゼゾ'.includes(c)) return 'サ';
  if ('タチツテトダヂヅデド'.includes(c)) return 'タ';
  if ('ナニヌネノ'.includes(c)) return 'ナ';
  if ('ハヒフヘホバビブベボパピプペポ'.includes(c)) return 'ハ';
  if ('マミムメモ'.includes(c)) return 'マ';
  if ('ヤユヨ'.includes(c)) return 'ヤ';
  if ('ラリルレロ'.includes(c)) return 'ラ';
  if ('ワヲン'.includes(c)) return 'ワ';
  return 'その他';
}
---

<BaseLayout title={title} description={description} path="/list">
  <Breadcrumbs items={[{ label: 'ポケカ買取・販売価格相場TOP', href: '/' }, { label: 'ポケモン一覧' }]} />
  <section class="list-hero">
    <div class="list-hero-inner">
      <div>
        <h1 class="page-title">ポケモン一覧</h1>
        <p class="lead">ポケモンカードに登場するポケモンを検索・閲覧できます。お気に入りのポケモンのカード相場をチェックしましょう。</p>
      </div>
    </div>
  </section>

  <section class="filter-panel page-panel">
    <div class="search-row">
      <input id="pokemonSearch" type="search" placeholder="ポケモン名で検索（例：ピカチュウ、リザードン）" aria-label="ポケモン名で検索" />
      <button type="button" id="clearFilters">条件をクリア</button>
    </div>
    <div class="filter-block">
      <p>タイプで絞り込む</p>
      <div class="chips" data-filter-group="type">
        {typeFilters.map((t) => <button type="button" class:list={[t === 'すべて' && 'active']} data-value={t}>{t}</button>)}
      </div>
    </div>
    <div class="filter-block">
      <p>名前で探す</p>
      <div class="chips compact" data-filter-group="initial">
        {initialFilters.map((i) => <button type="button" class:list={[i === 'すべて' && 'active']} data-value={i}>{i}</button>)}
      </div>
    </div>
    <div class="list-tools">
      <span id="resultCount">全 {list.length.toLocaleString()} 件</span>
    </div>
  </section>

  <section class="popular page-panel">
    <div class="section-head">
      <h2 class="section-title">人気のポケモン</h2>
      <a class="section-link" href="/ranking">人気順をもっと見る</a>
    </div>
    <ul class="popular-grid">
      {popular.map(({ series, top }) => (
        <li>
          <a href={`/list/${series.slug}`}>
            <img src={top.image} alt="" width="84" height="116" loading="lazy" />
            <span>{series.name}</span>
            <em>関連カード {series.variants.length}件</em>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <section class="all-list page-panel">
    <ul class="pokemon-grid" id="pokemonGrid">
      {
        entries.map(({ series, top, type, initial }) => (
          <li data-name={series.name} data-type={type} data-initial={initial}>
            <a href={`/list/${series.slug}`}>
              <img src={top.image} alt="" width="82" height="114" loading="lazy" />
              <span>{series.name}</span>
              <em>{series.variants.length}件</em>
            </a>
          </li>
        ))
      }
    </ul>
    <p id="empty" class="empty" hidden>該当するポケモンが見つかりませんでした。</p>
  </section>
</BaseLayout>

<script>
  const input = document.getElementById('pokemonSearch') as HTMLInputElement | null;
  const cards = [...document.querySelectorAll<HTMLLIElement>('#pokemonGrid li')];
  const count = document.getElementById('resultCount');
  const empty = document.getElementById('empty');
  let type = 'すべて';
  let initial = 'すべて';

  function normalize(s: string) {
    return s
      .replace(/[Ａ-Ｚａ-ｚ０-９]/g, (c) => String.fromCharCode(c.charCodeAt(0) - 0xfee0))
      .replace(/\s+/g, '')
      .toLowerCase();
  }
  function applyFilters() {
    const q = normalize(input?.value ?? '');
    let shown = 0;
    for (const card of cards) {
      const okName = !q || normalize(card.dataset.name ?? '').includes(q);
      const okType = type === 'すべて' || card.dataset.type === type;
      const okInitial = initial === 'すべて' || card.dataset.initial === initial;
      const visible = okName && okType && okInitial;
      card.hidden = !visible;
      if (visible) shown += 1;
    }
    if (count) count.textContent = `${shown.toLocaleString('ja-JP')} 件`;
    if (empty) empty.hidden = shown !== 0;
  }
  document.querySelectorAll<HTMLButtonElement>('.chips button').forEach((btn) => {
    btn.addEventListener('click', () => {
      const group = btn.closest<HTMLElement>('.chips')?.dataset.filterGroup;
      const value = btn.dataset.value ?? 'すべて';
      if (group === 'type') type = value;
      if (group === 'initial') initial = value;
      btn.parentElement?.querySelectorAll('button').forEach((b) => b.classList.toggle('active', b === btn));
      applyFilters();
    });
  });
  input?.addEventListener('input', applyFilters);
  document.getElementById('clearFilters')?.addEventListener('click', () => {
    if (input) input.value = '';
    type = 'すべて';
    initial = 'すべて';
    document.querySelectorAll<HTMLButtonElement>('.chips button').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.value === 'すべて');
    });
    applyFilters();
  });
</script>

<style>
  .list-hero { padding: 0 0 18px; }
  .list-hero-inner {
    max-width: 760px;
  }
  .page-title {
    margin: 0 0 12px;
    color: var(--text-strong);
    font-size: clamp(30px, 3.4vw, 36px);
    line-height: 1.3;
    font-weight: 900;
  }
  .lead {
    max-width: 720px;
    color: var(--text);
    font-size: 15px;
    line-height: 1.8;
    font-weight: 700;
    margin: 0;
  }
  .filter-panel {
    margin: 0 0 24px;
    padding: 24px 28px;
  }
  .search-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 210px;
    gap: 14px;
    margin-bottom: 22px;
  }
  .search-row input {
    width: 100%;
    min-height: 52px;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 0 18px;
    color: var(--text);
    font: inherit;
    font-weight: 700;
    background: #fff;
  }
  .search-row input:focus { outline: 2px solid rgba(7, 93, 204, 0.15); border-color: var(--brand); }
  .search-row button {
    border: 1px solid var(--border);
    border-radius: 10px;
    color: var(--text);
    background: #fff;
    font: inherit;
    font-size: 14px;
    font-weight: 900;
    cursor: pointer;
  }
  .filter-block + .filter-block { margin-top: 18px; }
  .filter-block p {
    margin: 0 0 10px;
    color: var(--text-strong);
    font-size: 14px;
    font-weight: 900;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .chips button {
    min-height: 46px;
    padding: 0 15px;
    border: 1px solid var(--border);
    border-radius: 9px;
    color: var(--text);
    background: #fff;
    font: inherit;
    font-size: 13px;
    font-weight: 800;
    cursor: pointer;
  }
  .chips.compact button { min-width: 58px; min-height: 40px; }
  .chips button.active {
    color: var(--brand);
    border-color: var(--brand);
    background: #f4f9ff;
    box-shadow: inset 0 0 0 1px var(--brand);
  }
  .list-tools {
    display: flex;
    justify-content: space-between;
    margin-top: 20px;
    padding-top: 18px;
    border-top: 1px solid var(--border);
    color: var(--brand);
    font-weight: 900;
  }
  .popular, .all-list {
    margin: 0 0 24px;
    padding: 26px 28px;
  }
  .popular-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    gap: 14px;
  }
  .popular-grid li {
    display: flex;
    min-width: 0;
  }
  .popular-grid a {
    width: 100%;
    height: 184px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-start;
    gap: 8px;
    padding: 12px 8px;
    border: 1px solid var(--border);
    border-radius: 10px;
    color: inherit;
    text-align: center;
    text-decoration: none;
    background: #fff;
  }
  .popular-grid a:hover, .pokemon-grid a:hover { border-color: var(--brand); box-shadow: var(--shadow-sm); }
  .popular-grid img {
    flex: 0 0 88px;
    width: 88px;
    height: 88px;
    object-fit: cover;
    object-position: top;
    border-radius: 8px;
  }
  .popular-grid span, .pokemon-grid span {
    color: var(--text-strong);
    font-size: 13px;
    line-height: 1.35;
    font-weight: 900;
  }
  .popular-grid span {
    min-height: 36px;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .popular-grid em, .pokemon-grid em {
    color: var(--text-sub);
    font-size: 11px;
    font-style: normal;
    font-weight: 700;
  }
  .popular-grid em {
    min-height: 15px;
    line-height: 1.35;
  }
  .pokemon-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(118px, 1fr));
    gap: 14px;
  }
  .pokemon-grid a {
    min-height: 152px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 7px;
    padding: 12px 8px;
    background: #fff;
    border: 1px solid var(--border);
    border-radius: 10px;
    text-decoration: none;
    color: var(--text);
    text-align: center;
  }
  .pokemon-grid img {
    width: 76px;
    height: 82px;
    object-fit: cover;
    object-position: top;
    border-radius: 8px;
  }
  .empty {
    margin: 18px 0 0;
    padding: 18px;
    border-radius: 10px;
    color: var(--text-sub);
    background: #f8fbff;
    text-align: center;
    font-weight: 700;
  }
  @media (max-width: 900px) {
    .popular-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .filter-panel, .popular, .all-list { padding: 20px 16px; }
    .search-row { grid-template-columns: 1fr; }
    .search-row button { min-height: 48px; }
    .popular-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .pokemon-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
</style>
