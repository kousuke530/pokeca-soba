---
// 旧カード詳細URL（/pack/[pack]/[card]）→ 新URL（/list/[slug]/[card]）への恒久リダイレクト。
// GitHub Pages は静的配信のため真のHTTP 301は返せない。instant meta refresh＋canonical＋JSで代替し、
// 検索エンジンには恒久移転（noindex,follow＋canonical）として伝える。
import { allCards } from '../../../data/cards';

export function getStaticPaths() {
  return allCards.map((card) => ({
    params: { pack: card.packSlug, card: `${card.cardNumber.replace(/\//g, '-')}-${card.raritySlug}` },
    props: { to: card.path },
  }));
}

const { to } = Astro.props as { to: string };
const dest = new URL(to, Astro.site).href;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="robots" content="noindex, follow" />
    <meta http-equiv="refresh" content={`0; url=${to}`} />
    <link rel="canonical" href={dest} />
    <title>ページが移動しました</title>
    <script is:inline set:html={`location.replace(${JSON.stringify(to)});`}></script>
  </head>
  <body>
    <p>このページは <a href={to}>新しいURL</a> に移動しました。</p>
  </body>
</html>
