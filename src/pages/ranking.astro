---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { topByPrice, priceAsOf } from '../data/cards';

const title = 'ポケカ高額カードランキング｜ポケカ相場ドットコム';
const description = 'ポケモンカードの販売価格が高い順のランキング。高額カードの最新相場を一覧で確認できます。';
const yen = (v: number | null) => (v == null ? '調査中' : `${v.toLocaleString('ja-JP')}円`);
const ranking = topByPrice(50);
const podium = ranking.slice(0, 3);
const rest = ranking.slice(3);
---

<BaseLayout title={title} description={description} path="/ranking">
  <Breadcrumbs items={[{ label: 'ポケカ買取・販売価格相場TOP', href: '/' }, { label: 'ランキング' }]} />
  <section class="ranking-hero">
    <div class="ranking-hero-inner">
      <div>
        <h1 class="page-title">高額カードランキング</h1>
        <p class="lead">取引相場が高いカードをランキング形式でご紹介。価格は{priceAsOf}時点の参考相場です。</p>
        <p class="updated">最終更新：{priceAsOf}</p>
      </div>
      <div class="hero-cards" aria-hidden="true">
        {ranking.slice(0, 3).map((c, i) => <img src={c.imageLarge} alt="" class={`hero-card hero-card-${i + 1}`} loading="eager" />)}
      </div>
    </div>
  </section>

  <section class="filter-bar page-panel" aria-label="ランキング条件">
    <label>期間<select><option>直近30日間</option></select></label>
    <label>カテゴリ<select><option>すべて</option></select></label>
    <label>レアリティ<select><option>すべて</option></select></label>
    <a href="/about">ランキングの見方</a>
  </section>

  <section class="podium" aria-label="上位3位">
    {
      podium.map((c) => {
        const originalRank = ranking.indexOf(c) + 1;
        return (
          <a href={c.path} class:list={['podium-card', `rank-${originalRank}`]}>
            <span class="podium-rank">{originalRank}</span>
            <img src={c.image} alt={c.name} width="150" height="210" loading="lazy" />
            <span class="podium-name">{c.name}</span>
            <span class="badge-rarity">{c.rarity}</span>
            <span class="podium-pack">{c.pack}</span>
            <strong>{yen(c.sellPrice)}</strong>
          </a>
        );
      })
    }
  </section>

  <p class="price-note">価格はカードショップの販売・買取価格をもとにした参考価格です。最新情報はカード詳細ページをご確認ください。</p>

  <ol class="rank-list page-panel" start="4">
    {
      rest.map((c, index) => (
        <li>
          <a href={c.path} class="rank-item">
            <span class="rank-no">{index + 4}</span>
            <img src={c.image} alt={c.name} width="70" height="98" loading="lazy" />
            <span class="rank-main">
              <span class="rank-name">{c.name}</span>
              <span class="rank-pack">{c.cardNumber} ／ {c.pack}</span>
            </span>
            <span class="badge-rarity">{c.rarity}</span>
            <span class="rank-price">{yen(c.sellPrice)}</span>
            <span class="go" aria-hidden="true"></span>
          </a>
        </li>
      ))
    }
  </ol>
</BaseLayout>

<style>
  .ranking-hero { padding: 0 0 18px; }
  .ranking-hero-inner {
    min-height: 290px;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(360px, 0.76fr);
    gap: 24px;
    align-items: center;
  }
  .page-title {
    margin: 0 0 12px;
    color: var(--text-strong);
    font-size: clamp(30px, 3.4vw, 36px);
    line-height: 1.3;
    font-weight: 900;
  }
  .lead {
    max-width: 720px;
    color: var(--text);
    font-size: 15px;
    line-height: 1.8;
    font-weight: 700;
    margin: 0 0 14px;
  }
  .updated { margin: 0; color: var(--text-sub); font-size: 14px; font-weight: 800; }
  .hero-cards { position: relative; min-height: 260px; }
  .hero-card {
    position: absolute;
    width: 150px;
    border-radius: 10px;
    filter: drop-shadow(0 16px 20px rgba(6, 40, 95, 0.18));
  }
  .hero-card-1 { left: 3%; top: 72px; transform: rotate(-12deg); }
  .hero-card-2 { left: 32%; top: 18px; z-index: 2; width: 182px; transform: rotate(3deg); }
  .hero-card-3 { right: 4%; top: 80px; transform: rotate(12deg); }
  .filter-bar {
    min-height: 76px;
    display: flex;
    align-items: center;
    gap: 24px;
    margin: 0 8px 34px;
    padding: 18px 28px;
  }
  .filter-bar label {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--text);
    font-size: 14px;
    font-weight: 900;
  }
  .filter-bar select {
    min-width: 150px;
    min-height: 42px;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 12px;
    background: #fff;
    font: inherit;
    font-weight: 700;
  }
  .filter-bar a {
    margin-left: auto;
    text-decoration: none;
    font-weight: 900;
  }
  .podium {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
    align-items: end;
    margin: 0 8px 22px;
  }
  .podium-card {
    position: relative;
    min-height: 250px;
    display: grid;
    grid-template-columns: 130px minmax(0, 1fr);
    gap: 16px;
    align-items: center;
    padding: 28px 22px 22px;
    border: 1px solid var(--border);
    border-radius: 16px;
    color: inherit;
    background: rgba(255, 255, 255, 0.94);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
  }
  .podium-card.rank-1 {
    min-height: 290px;
    border-color: #f6c453;
    background: linear-gradient(135deg, #fff, #fff7da);
  }
  .podium-card:hover { border-color: var(--brand); transform: translateY(-2px); }
  .podium-rank {
    position: absolute;
    left: 50%;
    top: -22px;
    transform: translateX(-50%);
    display: grid;
    place-items: center;
    width: 58px;
    height: 58px;
    border-radius: 50%;
    color: #fff;
    background: linear-gradient(145deg, #ffc928, #c87913);
    font-size: 28px;
    font-weight: 900;
  }
  .rank-2 .podium-rank { background: linear-gradient(145deg, #d8dde6, #8f99a8); }
  .rank-3 .podium-rank { background: linear-gradient(145deg, #d89758, #9a5622); }
  .podium-card img { width: 128px; height: 178px; object-fit: contain; border-radius: 7px; }
  .podium-name {
    display: block;
    color: var(--text-strong);
    font-size: 18px;
    line-height: 1.4;
    font-weight: 900;
  }
  .podium-pack {
    display: block;
    margin: 4px 0 8px;
    color: var(--text-sub);
    font-size: 13px;
    font-weight: 700;
  }
  .podium-card strong {
    display: block;
    color: var(--accent-red);
    font-size: 24px;
    line-height: 1.2;
    font-weight: 900;
    white-space: nowrap;
  }
  .price-note {
    margin: 0 8px 30px;
    padding: 13px 18px;
    border-radius: 10px;
    color: #6a4a00;
    background: #fff7d9;
    font-size: 13px;
    font-weight: 700;
    text-align: center;
  }
  .rank-list { list-style: none; margin: 0 8px; padding: 24px; display: flex; flex-direction: column; }
  .rank-list li + li { border-top: 1px solid var(--border); }
  .rank-item {
    display: grid;
    grid-template-columns: 54px 76px minmax(0, 1fr) 90px 180px 28px;
    align-items: center;
    gap: 18px;
    min-height: 112px;
    padding: 18px 0;
    text-decoration: none;
    color: inherit;
  }
  .rank-no {
    text-align: center;
    color: var(--brand);
    font-size: 27px;
    font-weight: 900;
  }
  .rank-item img { width: 68px; height: 94px; object-fit: contain; border-radius: 5px; }
  .rank-main { flex: 1; min-width: 0; }
  .rank-name { display: block; color: var(--text-strong); font-weight: 900; font-size: 16px; }
  .rank-pack { display: block; margin-top: 4px; font-size: 13px; color: var(--text-sub); font-weight: 700; }
  .rank-price {
    text-align: right;
    font-weight: 900;
    color: var(--accent-red);
    font-size: 24px;
    white-space: nowrap;
  }
  .go {
    position: relative;
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: #fff;
    color: var(--brand);
  }
  .go::before {
    content: "";
    width: 8px;
    height: 8px;
    border-top: 3px solid currentColor;
    border-right: 3px solid currentColor;
    transform: translateX(-1px) rotate(45deg);
  }
  @media (max-width: 940px) {
    .ranking-hero-inner { grid-template-columns: 1fr; }
    .hero-cards { display: none; }
    .filter-bar { flex-wrap: wrap; }
    .filter-bar a { margin-left: 0; }
    .podium { grid-template-columns: 1fr; }
    .podium-card, .podium-card.rank-1 { min-height: 0; }
    .rank-item {
      grid-template-columns: 42px 64px minmax(0, 1fr);
      gap: 12px;
    }
    .badge-rarity, .rank-price, .go { grid-column: 3; }
    .rank-price { text-align: left; }
  }
  @media (max-width: 560px) {
    .filter-bar, .rank-list { margin-inline: 0; padding: 18px 16px; }
    .filter-bar label { width: 100%; align-items: flex-start; flex-direction: column; }
    .filter-bar select { width: 100%; }
    .podium, .price-note { margin-inline: 0; }
    .podium-card { grid-template-columns: 104px minmax(0, 1fr); padding: 24px 16px 18px; }
    .podium-card img { width: 100px; height: 140px; }
    .podium-card strong { font-size: 22px; }
  }
</style>
